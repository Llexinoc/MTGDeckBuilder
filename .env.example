# Anthropic API Configuration
# Copy this file to .env and fill in your credentials to enable LLM enrichment
# .env is gitignored and should never be committed

# Anthropic API Key - required to enable LLM-based card re-ranking
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# (Optional) Specific Anthropic model to use for re-ranking
# Defaults to claude-3-5-haiku-20241022 if not set
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
